# Строка подключения к PostgreSQL.
# Локально (docker-compose): postgresql://postgres:postgres@localhost:5432/scheduler_dev
# Timeweb Cloud Managed PostgreSQL: возьмите из панели БД -> "Подключение" (host, port, user, password, dbname)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scheduler_dev

# Включите, если БД требует TLS-подключения (актуально для облачных провайдеров, в т.ч. Timeweb Cloud)
DATABASE_SSL=false

# Секрет для подписи JWT — сгенерируйте случайную строку (например: openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

PORT=3000
NODE_ENV=development

# Применять миграции автоматически при старте сервера — удобно для первого деплоя на PaaS без shell-доступа.
# На постоянной основе лучше запускать `node dist/db/migrate.js` отдельным шагом деплоя и держать это в false.
AUTO_MIGRATE=false

# Пароль администратора при первом запуске seed-скрипта (см. prisma/seed -> src/db/seed.ts)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-admin-password
